FROM pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/opt/CosyVoice:/opt/CosyVoice/third_party/Matcha-TTS

WORKDIR /app

ARG PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple
ARG PIP_TRUSTED_HOST=mirrors.aliyun.com

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      build-essential \
      ffmpeg \
      git \
      libsndfile1 \
      libsox-dev \
      sox \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements-tts-cosyvoice.txt requirements-tts-constraints.txt ./
RUN --mount=type=cache,target=/root/.cache/pip \
    python -m pip install --upgrade pip \
    && python -m pip install \
      --index-url "${PIP_INDEX_URL}" \
      --trusted-host "${PIP_TRUSTED_HOST}" \
      --constraint requirements-tts-constraints.txt \
      -r requirements.txt

COPY CosyVoice /opt/CosyVoice
RUN --mount=type=cache,target=/root/.cache/pip \
    python -m pip install \
      "setuptools<81" \
      wheel \
      numpy==1.26.4 \
      --index-url "${PIP_INDEX_URL}" \
      --trusted-host "${PIP_TRUSTED_HOST}" \
    && python -m pip install \
      --no-build-isolation \
      --index-url "${PIP_INDEX_URL}" \
      --trusted-host "${PIP_TRUSTED_HOST}" \
      --constraint requirements-tts-constraints.txt \
      -r requirements-tts-cosyvoice.txt \
    && python -m pip install \
      --no-build-isolation \
      --no-deps \
      --index-url "${PIP_INDEX_URL}" \
      --trusted-host "${PIP_TRUSTED_HOST}" \
      openai-whisper==20231117

RUN python -c "import cosyvoice.cli.cosyvoice; import cosyvoice.dataset.processor; import cosyvoice.flow.flow; import cosyvoice.flow.flow_matching; import cosyvoice.flow.DiT.dit; import cosyvoice.hifigan.discriminator; import cosyvoice.hifigan.f0_predictor; import cosyvoice.hifigan.generator; import cosyvoice.llm.llm; import cosyvoice.tokenizer.tokenizer; import matcha.hifigan.models; import matcha.utils.audio"

COPY app ./app

EXPOSE 8000

CMD ["python", "-m", "uvicorn", "app.tts_api:app", "--host", "0.0.0.0", "--port", "8000"]
