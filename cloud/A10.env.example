API_KEY=replace-with-a-long-random-secret
MODEL_NAME=HY-MT1.5-1.8B
MODEL_ID=/models/HY-MT1.5-1.8B
MODEL_BACKEND=transformers
MODEL_TASK=causal-lm
DEVICE=auto
TORCH_DTYPE=float16
MAX_NEW_TOKENS=1024
ASR_MODEL_NAME=Qwen3-ASR-1.7B
ASR_MODEL_ID=/models/Qwen3-ASR-1.7B-hf
ASR_BACKEND=qwen
ASR_DEVICE=auto
ASR_TORCH_DTYPE=bfloat16
ASR_MAX_NEW_TOKENS=512
ASR_MAX_UPLOAD_MB=200
ASR_STREAM_CHUNK_SECONDS=2.0
ASR_VAD_SILENCE_SECONDS=1.5
ASR_VAD_RMS_THRESHOLD=200
ASR_COMMIT_ON_PUNCTUATION=false
TTS_MODEL_NAME=CosyVoice
TTS_MODEL_ID=/models/CosyVoice
TTS_BACKEND=cosyvoice
TTS_DEVICE=auto
TTS_SAMPLE_RATE=24000
TTS_MAX_TEXT_CHARS=1000
TTS_DEFAULT_VOICE=default
TTS_COSYVOICE_REPO=/opt/CosyVoice
TRUST_REMOTE_CODE=true
