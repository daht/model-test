# Required: set to an independently generated test-environment secret.
API_KEY=

MODEL_NAME=HY-MT1.5-1.8B
MODEL_ID=/models/HY-MT1.5-1.8B
MODEL_BACKEND=transformers
MODEL_TASK=causal-lm
DEVICE=auto
TORCH_DTYPE=float16
MAX_NEW_TOKENS=1024

ASR_MODEL_NAME=SenseVoiceSmall
ASR_MODEL_ID=/models/SenseVoiceSmall
ASR_REQUIRE_MODEL_MANIFEST=true
ASR_MODEL_MANIFEST_PATH=/models/SenseVoiceSmall.manifest.json
ASR_BACKEND=sensevoice
ASR_STREAM_MODE=rolling
ASR_DEVICE=cuda:0
ASR_SENSEVOICE_BATCH_SIZE=8
ASR_SENSEVOICE_USE_ITN=true
ASR_DIAGNOSTIC_LOGGING=true
ASR_SLOW_ENGINE_LOG_SECONDS=2.0
ASR_STREAM_CHUNK_SECONDS=2.0
ASR_MAX_UTTERANCE_SECONDS=15.0
ASR_VAD_MODEL_PATH=/opt/asr-assets/silero_vad.onnx
ASR_VAD_MODEL_VERSION=6.2.1
ASR_VAD_MODEL_SHA256=1a153a22f4509e292a94e67d6f9b85e8deb25b4988682b7e174c65279d8788e3
ASR_VAD_FRAME_SAMPLES=512
ASR_VAD_ONSET_THRESHOLD=0.65
ASR_VAD_OFFSET_THRESHOLD=0.35
ASR_VAD_MIN_SPEECH_MS=250
ASR_VAD_MIN_SILENCE_MS=800
ASR_VAD_HANGOVER_MS=160
ASR_VAD_PRE_ROLL_MS=200
ASR_VAD_ONNX_INTRA_THREADS=1
ASR_VAD_ONNX_INTER_THREADS=1
ASR_PROTOCOL_VERSION=2
ASR_EAGER_LOAD=true
ASR_FILE_TRANSCRIBE_ENABLED=false
ASR_MAX_ACTIVE_STREAMS=64
ASR_INFERENCE_QUEUE_SIZE=128
ASR_MAX_QUEUED_AUDIO_SECONDS=64.0
ASR_MAX_CONNECTION_LAG_SECONDS=4.0
ASR_MAX_UNDECODED_AGE_SECONDS=8.0
ASR_MAX_FRAME_BYTES=16000
ASR_WS_MAX_QUEUE=4
ASR_START_TIMEOUT_SECONDS=20
ASR_IDLE_TIMEOUT_SECONDS=30
ASR_MAX_SESSION_SECONDS=1800
ASR_MAX_AUDIO_SECONDS=1800
ASR_STREAM_QUEUE_TIMEOUT_SECONDS=4.0
ASR_STREAM_INFERENCE_TIMEOUT_SECONDS=30.0
ASR_SHUTDOWN_GRACE_SECONDS=30.0
ASR_GATEWAY_SCHEDULE_MAX_WAIT_MS=200
ASR_GATEWAY_MAX_READY_JOBS=256
ASR_GATEWAY_MAX_QUEUED_AUDIO_SECONDS=128.0
ASR_GATEWAY_MAX_SESSION_BUFFER_SECONDS=6.0
ASR_GATEWAY_DEFAULT_UPDATE_MS=2000
ASR_GATEWAY_DRAIN_TIMEOUT_SECONDS=30
ASR_GATEWAY_DEFAULT_BACKEND=local
ASR_GATEWAY_MAX_ACTIVE_SESSIONS=64

TTS_MODEL_NAME=CosyVoice
TTS_MODEL_ID=/models/CosyVoice
TTS_BACKEND=mock
TTS_DEVICE=auto
TTS_SAMPLE_RATE=24000
TTS_MAX_TEXT_CHARS=1000
TTS_DEFAULT_VOICE=default
TTS_COSYVOICE_REPO=/opt/CosyVoice
TRUST_REMOTE_CODE=true
